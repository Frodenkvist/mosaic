<UserControl x:Class="Mosaic.Views.MediaLibraryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Mosaic.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:MediaLibraryViewModel}"
             d:DesignHeight="600" d:DesignWidth="900">
    <UserControl.Resources>
        <!-- Poster tile shared by the grid and the continue-watching strip. -->
        <DataTemplate x:Key="MediaTile" DataType="{x:Type vm:MediaTileViewModel}">
            <Border Width="180" Margin="10" Background="{StaticResource Surface}" CornerRadius="10"
                    Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ItemsControl}}">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftDoubleClick"
                                  Command="{Binding DataContext.OpenDetailCommand,
                                              RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                  CommandParameter="{Binding}" />
                </Border.InputBindings>
                <Border.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="▶  Play / Resume"
                                  Command="{Binding PlacementTarget.Tag.PlayCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                        <MenuItem Header="Details / Episodes"
                                  Command="{Binding PlacementTarget.Tag.OpenDetailCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                        <MenuItem Header="Remove…"
                                  Command="{Binding PlacementTarget.Tag.RemoveCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                    </ContextMenu>
                </Border.ContextMenu>

                <StackPanel>
                    <Grid Height="260">
                        <Border Background="{StaticResource SurfaceAlt}" CornerRadius="10,10,0,0">
                            <TextBlock Text="{Binding Title}" Foreground="{StaticResource TextMuted}"
                                       TextWrapping="Wrap" TextAlignment="Center"
                                       VerticalAlignment="Center" HorizontalAlignment="Center" Margin="8" />
                        </Border>
                        <Border CornerRadius="10,10,0,0" ClipToBounds="True">
                            <Image Source="{Binding PosterPath, Converter={StaticResource PathToImage}}"
                                   Stretch="UniformToFill" />
                        </Border>
                        <!-- Kind chip -->
                        <Border VerticalAlignment="Top" HorizontalAlignment="Left" Margin="8"
                                Background="#CC1B1C2A" CornerRadius="10" Padding="8,3">
                            <TextBlock Text="{Binding KindLabel}" Foreground="White" FontSize="10" FontWeight="SemiBold" />
                        </Border>
                        <!-- Watched check -->
                        <Border VerticalAlignment="Top" HorizontalAlignment="Right" Margin="8"
                                Background="#CC1FAA55" CornerRadius="12" Width="24" Height="24"
                                Visibility="{Binding IsWatched, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="✓" Foreground="White" FontWeight="Bold"
                                       VerticalAlignment="Center" HorizontalAlignment="Center" />
                        </Border>
                        <!-- Series progress -->
                        <Border VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="8"
                                Background="#CC1B1C2A" CornerRadius="10" Padding="8,3"
                                ToolTip="Episodes watched"
                                Visibility="{Binding HasEpisodeProgress, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="{Binding ProgressDisplay}" Foreground="White" FontSize="11" FontWeight="SemiBold" />
                        </Border>
                        <!-- Artwork fetch in progress -->
                        <Border VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="8"
                                Background="#CC6C5CE7" CornerRadius="10" Padding="8,3"
                                Visibility="{Binding IsFetchingArtwork, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="⟳ Fetching…" Foreground="White" FontSize="11" FontWeight="SemiBold" />
                        </Border>
                        <!-- Artwork fetch failed — click to retry -->
                        <Button VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="8"
                                Style="{StaticResource StatusPillButton}"
                                ToolTip="Couldn't fetch a poster — click to retry"
                                Visibility="{Binding ArtworkFetchFailed, Converter={StaticResource BoolToVisibility}}"
                                Command="{Binding DataContext.RetryArtworkCommand,
                                            RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                CommandParameter="{Binding MediaItemId}">
                            <TextBlock Text="⚠ Retry" Foreground="White" FontSize="11" FontWeight="SemiBold" />
                        </Button>
                    </Grid>
                    <TextBlock Text="{Binding Title}" Foreground="{StaticResource TextPrimary}"
                               FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Margin="12,8,12,0" />
                    <TextBlock Text="{Binding YearDisplay}" Foreground="{StaticResource TextSecondary}"
                               FontSize="12" Margin="12,2,12,0" />
                    <TextBlock Text="{Binding ResumeDisplay}" Foreground="{StaticResource TextMuted}"
                               FontSize="11" Margin="12,0,12,8"
                               Visibility="{Binding HasResume, Converter={StaticResource BoolToVisibility}}" />
                    <Grid Margin="10,0,10,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="▶ Play" Style="{StaticResource AccentButton}"
                                Command="{Binding DataContext.PlayCommand,
                                            RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                CommandParameter="{Binding}" />
                        <Button Grid.Column="1" Content="⋯" Margin="6,0,0,0" Padding="10,7"
                                Command="{Binding DataContext.OpenDetailCommand,
                                            RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                CommandParameter="{Binding}" />
                    </Grid>
                </StackPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Grid Grid.Row="0" Margin="12,0,12,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="🔍  Scan Media" Style="{StaticResource AccentButton}"
                    Command="{Binding ScanMediaCommand}" Margin="0,0,10,0"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" />
            <Button Grid.Column="1" Content="⟳  Refetch Art" Command="{Binding RefetchAllArtworkCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                    ToolTip="Fetch missing posters for all media" />

            <TextBox Grid.Column="3" Margin="0,0,10,0" Tag="Search media…"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
            <ComboBox Grid.Column="4" Width="170" ItemsSource="{Binding SortOptions}"
                      SelectedItem="{Binding SelectedSort}" />
        </Grid>

        <!-- Continue watching strip -->
        <StackPanel Grid.Row="1" Margin="12,0,12,8"
                    Visibility="{Binding HasContinueWatching, Converter={StaticResource BoolToVisibility}}">
            <TextBlock Text="Continue Watching" Foreground="{StaticResource TextSecondary}"
                       FontSize="14" FontWeight="SemiBold" Margin="10,0,0,2" />
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding ContinueWatching}" ItemTemplate="{StaticResource MediaTile}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </ScrollViewer>
        </StackPanel>

        <!-- Empty state -->
        <StackPanel Grid.Row="2" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}">
            <TextBlock Text="🎬" FontSize="46" HorizontalAlignment="Center" Opacity="0.5" />
            <TextBlock Text="No media yet" Foreground="{StaticResource TextSecondary}" FontSize="20"
                       HorizontalAlignment="Center" Margin="0,8,0,0" />
            <TextBlock Text="Add a media folder in Settings, then Scan Media to add your movies and shows."
                       Foreground="{StaticResource TextMuted}" FontSize="14" Margin="0,6,0,0"
                       HorizontalAlignment="Center" />
        </StackPanel>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="0,0,6,0">
            <ItemsControl ItemsSource="{Binding Items}" ItemTemplate="{StaticResource MediaTile}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
