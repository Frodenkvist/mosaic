<UserControl x:Class="Mosaic.Views.LibraryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Mosaic.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:LibraryViewModel}"
             d:DesignHeight="600" d:DesignWidth="900">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Grid Grid.Row="0" Margin="12,0,12,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="＋  Add Game" Style="{StaticResource AccentButton}"
                    Command="{Binding AddGameCommand}" Margin="0,0,10,0" />
            <Button Grid.Column="1" Content="🔍  Scan Folders" Command="{Binding ScanFoldersCommand}"
                    Margin="0,0,10,0" />
            <Button Grid.Column="2" Content="⟳  Refetch Art" Command="{Binding RefetchAllArtworkCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                    ToolTip="Fetch missing cover art for all games" />

            <!-- Search -->
            <TextBox Grid.Column="4" Margin="0,0,10,0" Tag="Search library…"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

            <ComboBox Grid.Column="5" Width="170" ItemsSource="{Binding SortOptions}"
                      SelectedItem="{Binding SelectedSort}" />
        </Grid>

        <!-- Empty state -->
        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}">
            <TextBlock Text="🎮" FontSize="46" HorizontalAlignment="Center" Opacity="0.5" />
            <TextBlock Text="Your library is empty" Foreground="{StaticResource TextSecondary}" FontSize="20"
                       HorizontalAlignment="Center" Margin="0,8,0,0" />
            <TextBlock Text="Add a game or scan a folder to get started."
                       Foreground="{StaticResource TextMuted}" FontSize="14" Margin="0,6,0,0"
                       HorizontalAlignment="Center" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,6,0">
            <ItemsControl ItemsSource="{Binding Games}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:GameTileViewModel}">
                        <Border Width="180" Margin="10" Background="{StaticResource Surface}" CornerRadius="10"
                                Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ItemsControl}}">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftDoubleClick"
                                              Command="{Binding DataContext.OpenDetailCommand,
                                                          RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                              CommandParameter="{Binding}" />
                            </Border.InputBindings>
                            <Border.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="▶  Play"
                                              Command="{Binding PlacementTarget.Tag.LaunchCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    <MenuItem Header="Details / Edit"
                                              Command="{Binding PlacementTarget.Tag.OpenDetailCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    <MenuItem Header="Remove…"
                                              Command="{Binding PlacementTarget.Tag.RemoveCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                </ContextMenu>
                            </Border.ContextMenu>

                            <StackPanel>
                                <Grid Height="240">
                                    <Border Background="{StaticResource SurfaceAlt}" CornerRadius="10,10,0,0">
                                        <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextMuted}"
                                                   TextWrapping="Wrap" TextAlignment="Center"
                                                   VerticalAlignment="Center" HorizontalAlignment="Center" Margin="8" />
                                    </Border>
                                    <Border CornerRadius="10,10,0,0" ClipToBounds="True">
                                        <Image Source="{Binding CoverPath, Converter={StaticResource PathToImage}}"
                                               Stretch="UniformToFill" />
                                    </Border>
                                    <!-- Running badge -->
                                    <Border VerticalAlignment="Top" HorizontalAlignment="Right" Margin="8"
                                            Background="#CC1FAA55" CornerRadius="10" Padding="8,3"
                                            Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibility}}">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="8" Height="8" Fill="White" VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding LiveElapsedDisplay}" Foreground="White"
                                                       FontSize="11" FontWeight="SemiBold" Margin="6,0,0,0" />
                                        </StackPanel>
                                    </Border>
                                    <!-- Artwork fetch in progress -->
                                    <Border VerticalAlignment="Top" HorizontalAlignment="Left" Margin="8"
                                            Background="#CC6C5CE7" CornerRadius="10" Padding="8,3"
                                            Visibility="{Binding IsFetchingArtwork, Converter={StaticResource BoolToVisibility}}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="⟳" Foreground="White" FontSize="11" VerticalAlignment="Center" />
                                            <TextBlock Text="Fetching art…" Foreground="White"
                                                       FontSize="11" FontWeight="SemiBold" Margin="6,0,0,0" />
                                        </StackPanel>
                                    </Border>
                                    <!-- Artwork fetch failed — click to retry -->
                                    <Button VerticalAlignment="Top" HorizontalAlignment="Left" Margin="8"
                                            Style="{StaticResource StatusPillButton}"
                                            ToolTip="Couldn't fetch cover art — click to retry"
                                            Visibility="{Binding ArtworkFetchFailed, Converter={StaticResource BoolToVisibility}}"
                                            Command="{Binding DataContext.RetryArtworkCommand,
                                                        RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding GameId}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="⚠" Foreground="White" FontSize="11" VerticalAlignment="Center" />
                                            <TextBlock Text="Retry art" Foreground="White"
                                                       FontSize="11" FontWeight="SemiBold" Margin="6,0,0,0" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                                <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextPrimary}"
                                           FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Margin="12,8,12,0" />
                                <TextBlock Text="{Binding PlayTimeDisplay}" Foreground="{StaticResource TextSecondary}"
                                           FontSize="12" Margin="12,2,12,0" />
                                <TextBlock Text="{Binding LastPlayedDisplay}" Foreground="{StaticResource TextMuted}"
                                           FontSize="11" Margin="12,0,12,8" />
                                <Grid Margin="10,0,10,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Content="▶ Play" Style="{StaticResource AccentButton}"
                                            IsEnabled="{Binding CanLaunch}"
                                            Command="{Binding DataContext.LaunchCommand,
                                                        RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}" />
                                    <Button Grid.Column="1" Content="⋯" Margin="6,0,0,0" Padding="10,7"
                                            Command="{Binding DataContext.OpenDetailCommand,
                                                        RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
