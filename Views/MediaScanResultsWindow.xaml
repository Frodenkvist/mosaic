<theming:MosaicWindow x:Class="Mosaic.Views.MediaScanResultsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:theming="clr-namespace:Mosaic.Theming"
        xmlns:vm="clr-namespace:Mosaic.ViewModels"
        mc:Ignorable="d"
        Title="Media scan results" Height="600" Width="720" ShowCaptionMinMax="False"
        Icon="/Mosaic.ico" WindowStartupLocation="CenterOwner"
        Style="{StaticResource MosaicWindowStyle}"
        d:DataContext="{d:DesignInstance Type=vm:MediaScanResultsViewModel}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap"
                   Text="Select the movies and episodes to add. Uncheck anything that isn't media; edit a title to relabel it (episodes are grouped under the title you give)." />

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12">
            <Button Content="Select all" Command="{Binding SelectAllCommand}" Margin="0,0,8,0" />
            <Button Content="Select none" Command="{Binding SelectNoneCommand}" />
        </StackPanel>

        <Border Grid.Row="2" Background="{StaticResource Surface}" CornerRadius="8" Padding="6">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Candidates}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:MediaScanCandidateViewModel}">
                            <Border Margin="4,3" Padding="10" Background="{StaticResource SurfaceAlt}" CornerRadius="6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="240" />
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="1" Margin="8,0">
                                        <TextBox Text="{Binding DisplayTitle, UpdateSourceTrigger=PropertyChanged}"
                                                 FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding FilePath}" FontSize="11"
                                                   Foreground="{StaticResource TextMuted}"
                                                   TextTrimming="CharacterEllipsis" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="{Binding KindLabel}" VerticalAlignment="Center"
                                               Foreground="{StaticResource TextSecondary}" FontSize="12"
                                               TextAlignment="Right" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancel" Width="100" Margin="0,0,8,0" IsCancel="True" Click="Cancel_Click" />
            <Button Content="Add selected" Width="130" Style="{StaticResource AccentButton}"
                    IsDefault="True" Click="Ok_Click" />
        </StackPanel>
    </Grid>
</theming:MosaicWindow>
