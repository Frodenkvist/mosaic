<theming:MosaicWindow x:Class="Mosaic.Views.MediaDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:theming="clr-namespace:Mosaic.Theming"
        xmlns:vm="clr-namespace:Mosaic.ViewModels"
        mc:Ignorable="d"
        Title="Media details" Height="720" Width="780" ShowCaptionMinMax="True"
        Icon="/Mosaic.ico" WindowStartupLocation="CenterOwner"
        Style="{StaticResource MosaicWindowStyle}"
        d:DataContext="{d:DesignInstance Type=vm:MediaDetailViewModel}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
            <StackPanel>
                <!-- Header: poster + metadata -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Height="300" CornerRadius="10" ClipToBounds="True"
                            Background="{StaticResource SurfaceAlt}">
                        <Grid>
                            <TextBlock Text="No poster" Foreground="{StaticResource TextMuted}"
                                       VerticalAlignment="Center" HorizontalAlignment="Center" />
                            <Image Source="{Binding PosterPath, Converter={StaticResource PathToImage}}"
                                   Stretch="UniformToFill" />
                        </Grid>
                    </Border>

                    <StackPanel Grid.Column="1" Margin="18,0,0,0">
                        <TextBlock Text="Title" Foreground="{StaticResource TextMuted}" FontSize="11" />
                        <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" FontSize="18" FontWeight="SemiBold" />

                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <StackPanel Margin="0,0,16,0">
                                <TextBlock Text="Year" Foreground="{StaticResource TextMuted}" FontSize="11" />
                                <TextBox Text="{Binding EditYear, UpdateSourceTrigger=PropertyChanged}" Width="80" />
                            </StackPanel>
                            <TextBlock Text="{Binding ProgressDisplay}" Foreground="{StaticResource TextSecondary}"
                                       VerticalAlignment="Bottom" Margin="0,0,0,6"
                                       Visibility="{Binding HasProgress, Converter={StaticResource BoolToVisibility}}" />
                        </StackPanel>

                        <TextBlock Text="{Binding NextUpDisplay}" Foreground="{StaticResource TextSecondary}"
                                   Margin="0,12,0,0" TextWrapping="Wrap"
                                   Visibility="{Binding IsSeries, Converter={StaticResource BoolToVisibility}}" />
                        <TextBlock Text="{Binding ResumeDisplay}" Foreground="{StaticResource TextMuted}"
                                   Margin="0,6,0,0"
                                   Visibility="{Binding IsMovie, Converter={StaticResource BoolToVisibility}}" />

                        <!-- Movie actions -->
                        <StackPanel Orientation="Horizontal" Margin="0,16,0,0"
                                    Visibility="{Binding IsMovie, Converter={StaticResource BoolToVisibility}}">
                            <Button Content="▶ Play" Style="{StaticResource AccentButton}" Command="{Binding PlayMovieCommand}" />
                            <Button Content="{Binding MovieWatchLabel}" Margin="8,0,0,0" Command="{Binding ToggleWatchedMovieCommand}" />
                        </StackPanel>
                        <!-- Series actions -->
                        <StackPanel Orientation="Horizontal" Margin="0,16,0,0"
                                    Visibility="{Binding IsSeries, Converter={StaticResource BoolToVisibility}}">
                            <Button Content="▶ Resume" Style="{StaticResource AccentButton}" Command="{Binding ResumeSeriesCommand}" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <Button Content="⟳ Refresh metadata" Command="{Binding RefreshMetadataCommand}" Margin="0,0,8,0" />
                            <Button Content="Set poster…" Command="{Binding SetPosterCommand}" />
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <!-- Series: seasons + episodes -->
                <ItemsControl ItemsSource="{Binding Seasons}" Margin="0,18,0,0"
                              Visibility="{Binding IsSeries, Converter={StaticResource BoolToVisibility}}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:SeasonGroupViewModel}">
                            <StackPanel Margin="0,0,0,14">
                                <TextBlock Text="{Binding Header}" Foreground="{StaticResource TextPrimary}"
                                           FontSize="15" FontWeight="SemiBold" Margin="0,0,0,6" />
                                <ItemsControl ItemsSource="{Binding Episodes}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:EpisodeRowViewModel}">
                                            <Border Margin="0,3" Padding="8" Background="{StaticResource Surface}" CornerRadius="6">
                                                <StackPanel>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="120" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" Height="68" CornerRadius="4" ClipToBounds="True"
                                                            Background="{StaticResource SurfaceAlt}">
                                                        <Image Source="{Binding StillPath, Converter={StaticResource PathToImage}}"
                                                               Stretch="UniformToFill" />
                                                    </Border>
                                                    <StackPanel Grid.Column="1" Margin="10,0" VerticalAlignment="Center">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding EpisodeLabel}" Foreground="{StaticResource Accent}"
                                                                       FontWeight="SemiBold" Margin="0,0,8,0" />
                                                            <TextBlock Text="{Binding Title}" Foreground="{StaticResource TextPrimary}"
                                                                       TextTrimming="CharacterEllipsis" />
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding ResumeDisplay}" Foreground="{StaticResource TextMuted}"
                                                                   FontSize="11" Margin="0,2,0,0"
                                                                   Visibility="{Binding HasResume, Converter={StaticResource BoolToVisibility}}" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                        <Button Content="▶" Padding="10,6" ToolTip="Play"
                                                                Command="{Binding DataContext.PlayEpisodeCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                                CommandParameter="{Binding}" />
                                                        <Button Content="{Binding WatchLabel}" Margin="6,0,0,0"
                                                                Command="{Binding DataContext.ToggleEpisodeWatchedCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                                CommandParameter="{Binding}" />
                                                        <Button Content="✓▶" Margin="6,0,0,0" ToolTip="Mark watched and play next"
                                                                Command="{Binding DataContext.MarkWatchedAndPlayNextCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                                CommandParameter="{Binding}" />
                                                        <Button Content="✎" Margin="6,0,0,0" Padding="10,6" ToolTip="Edit season/episode number or title"
                                                                Command="{Binding DataContext.BeginEditEpisodeCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                                CommandParameter="{Binding}" />
                                                        <Button Content="🗑" Margin="6,0,0,0" Padding="10,6" ToolTip="Remove this episode"
                                                                Command="{Binding DataContext.RemoveEpisodeCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                                CommandParameter="{Binding}" />
                                                    </StackPanel>
                                                </Grid>

                                                <!-- Inline editor: correct a mis-parsed season/episode number or title -->
                                                <Border Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}"
                                                        Margin="0,8,0,0" Padding="10" CornerRadius="4"
                                                        Background="{StaticResource SurfaceAlt}">
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal">
                                                            <StackPanel Margin="0,0,12,0">
                                                                <TextBlock Text="Season" Foreground="{StaticResource TextMuted}" FontSize="11" />
                                                                <TextBox Width="60" Text="{Binding EditSeason, UpdateSourceTrigger=PropertyChanged}" />
                                                            </StackPanel>
                                                            <StackPanel Margin="0,0,12,0">
                                                                <TextBlock Text="Episode" Foreground="{StaticResource TextMuted}" FontSize="11" />
                                                                <TextBox Width="60" Text="{Binding EditEpisode, UpdateSourceTrigger=PropertyChanged}" />
                                                            </StackPanel>
                                                            <StackPanel>
                                                                <TextBlock Text="Title" Foreground="{StaticResource TextMuted}" FontSize="11" />
                                                                <TextBox Width="320" Text="{Binding EditTitle, UpdateSourceTrigger=PropertyChanged}" />
                                                            </StackPanel>
                                                        </StackPanel>
                                                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                                            <Button Content="Save" Style="{StaticResource AccentButton}"
                                                                    Command="{Binding DataContext.SaveEpisodeCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                                    CommandParameter="{Binding}" />
                                                            <Button Content="Cancel" Margin="8,0,0,0"
                                                                    Command="{Binding DataContext.CancelEditEpisodeCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                                    CommandParameter="{Binding}" />
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <!-- Pinned footer -->
        <Grid Grid.Row="1" Margin="0,14,0,0">
            <Button Content="Remove…" HorizontalAlignment="Left" Command="{Binding RemoveCommand}" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Save &amp; Close" Width="130" Style="{StaticResource AccentButton}"
                        Command="{Binding SaveCommand}" />
                <Button Content="Close" Width="90" Margin="8,0,0,0" Command="{Binding CloseCommand}" />
            </StackPanel>
        </Grid>
    </Grid>
</theming:MosaicWindow>
