<theming:MosaicWindow x:Class="Mosaic.Views.GameDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:theming="clr-namespace:Mosaic.Theming"
        xmlns:vm="clr-namespace:Mosaic.ViewModels"
        mc:Ignorable="d"
        Title="{Binding Name}" Height="720" Width="800" MinHeight="420" MinWidth="680"
        Icon="/Mosaic.ico" WindowStartupLocation="CenterOwner"
        Style="{StaticResource MosaicWindowStyle}"
        d:DataContext="{d:DesignInstance Type=vm:GameDetailViewModel}">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="270" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Cover + stats -->
        <StackPanel Grid.Column="0" Margin="0,0,20,0">
            <Border Height="360" Background="{StaticResource SurfaceAlt}" CornerRadius="10" ClipToBounds="True">
                <Grid>
                    <TextBlock Text="No cover" Foreground="{StaticResource TextMuted}"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <Image Source="{Binding CoverPath, Converter={StaticResource PathToImage}}" Stretch="UniformToFill" />
                </Grid>
            </Border>
            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="Set cover…" Command="{Binding SetCoverCommand}" Margin="0,0,4,0" />
                <Button Grid.Column="1" Content="Refetch art" Command="{Binding RefetchArtworkCommand}" Margin="4,0,0,0" />
            </Grid>

            <Border Background="{StaticResource Surface}" CornerRadius="10" Padding="14" Margin="0,16,0,0">
                <StackPanel>
                    <TextBlock Text="TOTAL PLAY TIME" Foreground="{StaticResource TextMuted}" FontSize="11" />
                    <TextBlock Text="{Binding PlayTimeDisplay}" Foreground="{StaticResource TextPrimary}"
                               FontSize="20" FontWeight="SemiBold" Margin="0,2,0,0" />
                    <TextBlock Text="LAST PLAYED" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,12,0,0" />
                    <TextBlock Text="{Binding LastPlayedDisplay}" Foreground="{StaticResource TextPrimary}"
                               FontSize="14" Margin="0,2,0,0" />
                </StackPanel>
            </Border>

            <Grid Margin="0,16,0,0">
                <Button Content="▶  Play" Style="{StaticResource AccentButton}" Command="{Binding LaunchCommand}"
                        Padding="0,13" FontSize="15" IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBool}}" />
                <Border Background="#CC1FAA55" CornerRadius="6" Padding="10,4" HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="9" Height="9" Fill="White" VerticalAlignment="Center" />
                        <TextBlock Text="Running" Foreground="White" FontWeight="SemiBold" Margin="7,0,0,0" />
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>

        <!-- Title + editor -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="{Binding Name}" Foreground="{StaticResource TextPrimary}"
                       FontSize="24" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Margin="0,0,0,14" />

            <Expander Grid.Row="1" Header="Edit details" IsExpanded="True"
                      Foreground="{StaticResource TextSecondary}" VerticalAlignment="Top">
                <StackPanel Margin="0,8,0,0">
                    <StackPanel.Resources>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
                            <Setter Property="Margin" Value="0,10,0,4" />
                            <Setter Property="FontSize" Value="13" />
                        </Style>
                    </StackPanel.Resources>

                    <TextBlock Text="Name" Margin="0,0,0,4" />
                    <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Text="Executable" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding ExecutablePath, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Grid.Column="1" Content="Browse…" Margin="8,0,0,0"
                                Command="{Binding BrowseExecutableCommand}" />
                    </Grid>

                    <TextBlock Text="Launch arguments" />
                    <TextBox Text="{Binding LaunchArguments, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Text="Working directory" />
                    <TextBox Text="{Binding WorkingDirectory, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Text="Real executable for play tracking (e.g. game.exe)" />
                    <TextBox Text="{Binding RealExecutableName, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
            </Expander>

            <DockPanel Grid.Row="2" Margin="0,16,0,0">
                <TextBlock DockPanel.Dock="Left" Text="{Binding StatusMessage}" Foreground="#7BD88F"
                           VerticalAlignment="Center" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Remove" Style="{StaticResource DangerButton}" Command="{Binding RemoveCommand}"
                            Width="100" Margin="0,0,8,0" />
                    <Button Content="Save &amp; Close" Style="{StaticResource AccentButton}"
                            Command="{Binding SaveCommand}" Width="120" IsDefault="True" />
                </StackPanel>
            </DockPanel>
        </Grid>
    </Grid>
    </ScrollViewer>
</theming:MosaicWindow>
