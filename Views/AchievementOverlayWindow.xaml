<Window x:Class="Mosaic.Views.AchievementOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" ShowActivated="False" Topmost="True" ResizeMode="NoResize"
        Focusable="False" IsHitTestVisible="False"
        Width="440" Height="120" Left="0" Top="0">
    <!-- Width/Height fixed and small so the window is a tiny transparent region; the toast is the
         only thing ever painted, and it is Collapsed when idle so nothing is visible. -->
    <Grid>
        <Border x:Name="ToastRoot" Visibility="Collapsed" Opacity="0"
                VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,8,0,0"
                Background="{StaticResource SurfaceAlt}" CornerRadius="10" Padding="14,12" MaxWidth="420">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="18" ShadowDepth="0" Opacity="0.6" />
            </Border.Effect>
            <Border.RenderTransform>
                <TranslateTransform x:Name="ToastSlide" Y="-12" />
            </Border.RenderTransform>
            <StackPanel Orientation="Horizontal">
                <Border Width="46" Height="46" CornerRadius="6" Background="{StaticResource Surface}" ClipToBounds="True">
                    <Image x:Name="ToastIcon" Stretch="UniformToFill" />
                </Border>
                <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="🏆 Achievement unlocked" Foreground="{StaticResource Accent}"
                               FontSize="11" FontWeight="SemiBold" />
                    <TextBlock x:Name="ToastTitle" Foreground="{StaticResource TextPrimary}"
                               FontWeight="SemiBold" TextTrimming="CharacterEllipsis" MaxWidth="340" />
                    <TextBlock x:Name="ToastSubtitle" Foreground="{StaticResource TextSecondary}" FontSize="12" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
