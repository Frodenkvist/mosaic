<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
                    xmlns:theming="clr-namespace:Mosaic.Theming">

    <!-- Caption button base look -->
    <Style x:Key="CaptionButtonBase" TargetType="Button">
        <Setter Property="Width" Value="46" />
        <Setter Property="Height" Value="40" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{DynamicResource Hover}" />
                            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Minimize / maximize: collapse when ShowCaptionMinMax is false -->
    <Style x:Key="CaptionMinMaxButton" TargetType="Button" BasedOn="{StaticResource CaptionButtonBase}">
        <Style.Triggers>
            <DataTrigger Binding="{Binding ShowCaptionMinMax, RelativeSource={RelativeSource AncestorType=theming:MosaicWindow}}"
                         Value="False">
                <Setter Property="Visibility" Value="Collapsed" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- Close: red hover -->
    <Style x:Key="CaptionCloseButton" TargetType="Button" BasedOn="{StaticResource CaptionButtonBase}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#E81123" />
                            <Setter Property="Foreground" Value="White" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- The window style (applied explicitly via Style="{StaticResource MosaicWindowStyle}"
         on each window, because implicit styles match the exact type, not derived types) -->
    <Style x:Key="MosaicWindowStyle" TargetType="{x:Type theming:MosaicWindow}">
        <Setter Property="Background" Value="{DynamicResource WindowBg}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
        <Setter Property="WindowStyle" Value="SingleBorderWindow" />
        <Setter Property="shell:WindowChrome.WindowChrome">
            <Setter.Value>
                <shell:WindowChrome CaptionHeight="40" ResizeBorderThickness="6"
                                    CornerRadius="0" GlassFrameThickness="0" UseAeroCaptionButtons="False" />
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type theming:MosaicWindow}">
                    <Border x:Name="rootBorder" Background="{DynamicResource WindowBg}"
                            BorderBrush="{DynamicResource Border}" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="40" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!-- Title bar -->
                            <Border Grid.Row="0" Background="{DynamicResource Surface}"
                                    BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1">
                                <Grid>
                                    <StackPanel Orientation="Horizontal" Margin="12,0" VerticalAlignment="Center">
                                        <Image Source="/Mosaic.png" Width="20" Height="20"
                                               RenderOptions.BitmapScalingMode="HighQuality" />
                                        <TextBlock Text="{TemplateBinding Title}" Foreground="{DynamicResource TextSecondary}"
                                                   Margin="10,0,0,0" VerticalAlignment="Center" FontSize="12" />
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                                        <Button x:Name="PART_Minimize" Style="{StaticResource CaptionMinMaxButton}"
                                                Content="&#xE921;" ToolTip="Minimize" />
                                        <Button x:Name="PART_Maximize" Style="{StaticResource CaptionMinMaxButton}"
                                                Content="&#xE922;" ToolTip="Maximize" />
                                        <Button x:Name="PART_Close" Style="{StaticResource CaptionCloseButton}"
                                                Content="&#xE8BB;" ToolTip="Close" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <ContentPresenter Grid.Row="1" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="WindowState" Value="Maximized">
                            <!-- Keep content on-screen when maximized (chrome overshoots by the resize border) -->
                            <Setter TargetName="rootBorder" Property="Padding" Value="7" />
                            <Setter TargetName="rootBorder" Property="BorderThickness" Value="0" />
                            <Setter TargetName="PART_Maximize" Property="Content" Value="&#xE923;" />
                            <Setter TargetName="PART_Maximize" Property="ToolTip" Value="Restore" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
